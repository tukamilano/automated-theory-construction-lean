# Root-level Makefile reads `.env` automatically when present.
# This file is only a template for local defaults.

# Common command wrappers
PYTHON=python3
UV=uv
WORKER_COMMAND=uv run python scripts/codex_worker.py

# Common loop defaults
MAX_ITERATIONS=5
WORKER_TIMEOUT=420
CODEX_TIMEOUT=390
SEED_COUNT=4

# Optional context file used by `make seed-dry-run` and `make pipeline-dry-run`
# CONTEXT_FILE=path/to/context-file.tex

# Optional Derived.lean refactor defaults used by `make refactor-preview`,
# `make refactor-review`, and `make refactor-all`
# REFACTOR_WORKER_COMMAND=uv run python scripts/codex_worker.py
# REFACTOR_WORKER_TIMEOUT=
# REFACTOR_VERIFY_TIMEOUT=
# PREVIEW_FILE=AutomatedTheoryConstruction/Derived.refactored.preview.lean
# REVIEW_OUTPUT_FILE=AutomatedTheoryConstruction/Derived.refactored.reviewed.lean
# REVIEW_MODEL=
# REVIEW_SANDBOX=workspace-write
# SKIP_REVIEW_COPY=
# NO_REVIEW_VERIFY=

# Runtime variables used by direct CLI invocation
ATC_WORKER_COMMAND=uv run python scripts/codex_worker.py
ATC_WORKER_TIMEOUT=420
ATC_CODEX_TIMEOUT=390
# ATC_CODEX_MODEL=
# ATC_PROVER_CODEX_MODEL=
# ATC_FORMALIZE_WORKER_TIMEOUT=
# ATC_REPAIR_WORKER_TIMEOUT=
