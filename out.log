 hA : 1 ≤ tp_degree A := by\n        cases A <;> simp [tp_degree]\n      have hΓ : Γ.length ≤ list_degree Γ := list_length_le_list_degree Γ\n      calc\n        (A :: Γ).length = Γ.length + 1 := by simp\n        _ = 1 + Γ.length := by omega\n        _ ≤ tp_degree A + list_degree Γ := Nat.add_le_add hA hΓ\n        _ = list_degree (A :: Γ) := by simp [list_degree]\n\nlemma atomicResidualGraphStep_degree_lt {p q : AtomicResidualState}\n    (h : AtomicResidualGraphStep p q) :\n    list_degree q.1 < list_degree p.1 := by\n  cases h with\n  | rdiv Γ L Δ Λ A B s hc harg =>\n      have hΓ : Γ = L ++ [Tp.rdiv B A] ++ Δ ++ Λ := by\n        symm\n        simpa using (candidates_list_degree (Γ := Γ) (c := Cand.rdiv L B A Δ Λ) hc)\n      rw [hΓ]\n      simp [list_degree_traversible, List.append_assoc, list_degree, tp_degree]\n      omega\n  | ldiv Γ Γ₁ Δ R A B s hc harg =>\n      have hΓ : Γ = Γ₁ ++ Δ ++ [Tp.ldiv A B] ++ R := by\n        symm\n        simpa using (candidates_list_degree (Γ := Γ) (c := Cand.ldiv Γ₁ Δ A B R) hc)\n      rw [hΓ]\n      simp [list_degree_traversible, List.append_assoc, list_degree, tp_degree]\n      omega\n\nlemma residual_reachable_degree_le {p q : AtomicResidualState}\n    (h : Relation.ReflTransGen AtomicResidualGraphStep p q) :\n    list_degree q.1 ≤ list_degree p.1 := by\n  induction h with\n  | refl =>\n      exact le_rfl\n  | tail hreach hstep ih =>\n      exact le_trans (atomicResidualGraphStep_degree_lt hstep).le ih', 'prover_statement_result': 'ok', 'prover_attempts_used': 1, 'priority_refresh_ran': True, 'priority_refresh_error': '', 'expand_candidates': [{'statement': 'AtomicResidualGraphStep is well-founded on AtomicResidualState.', 'rationale': 'The solved proof exposed strict `list_degree` descent on every residual step. Promoting that from an in-proof device to a standalone global theorem would make residual termination reusable across later arguments, especially finite-search, bounded-branch, and fixed-point constructions for internal recognition.'}, {'statement': '∀ (Γ Δ : List Tp) (A : Tp) (s : String), residualAtomicState Γ A = some (Δ, s) → every finite residual path starting at (Δ, s) has length at most list_degree Δ.', 'rationale': 'This sharpens reachable-set finiteness to a uniform height bound on residual exploration. That gives a direct, input-determined search cap for exact internal recognition and explains the global shape of the reachable region more clearly than finiteness alone.'}, {'statement': 'There exist Γ, A, Δ, s, and a state p such that residualAtomicState Γ A = some (Δ, s), p.2 = s, list_degree p.1 ≤ list_degree Δ, every formula in p.1 is a subformula of some formula in Γ ++ [A], but p is not reachable from (Δ, s) by residual-graph steps.', 'rationale': 'The resolved theorem proves finiteness by embedding reachability into a finite same-atom, subformula-bounded, degree-bounded ambient slice. This candidate asks whether that finite slice is already exact or still a strict overapproximation, which is a central boundary question for building an exact finite internal residual machine.'}], 'stored_expand_rows': [{'id': 'op_000078', 'stmt': 'AtomicResidualGraphStep is well-founded on AtomicResidualState.', 'src': 'expand', 'mode': 'expand_candidate', 'summary_delta': 'The solved proof exposed strict `list_degree` descent on every residual step. Promoting that from an in-proof device to a standalone global theorem would make residual termination reusable across later arguments, especially finite-search, bounded-branch, and fixed-point constructions for internal recognition.', 'source_kind': 'expand_candidate', 'generated_from_source_id': 'op_000071', 'generated_from_source_kind': 'open_problem', 'priority': 'unknown', 'priority_rationale': '', 'failure_count': 0, 'parent_problem_ids': []}, {'id': 'op_000079', 'stmt': '∀ (Γ Δ : List Tp) (A : Tp) (s : String), residualAtomicState Γ A = some (Δ, s) → every finite residual path starting at (Δ, s) has length at most list_degree Δ.', 