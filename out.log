e Boolean labeling, and that labeling agrees exactly with `AtomicResidualGraphAccepts` on the reachable states.', 'statement_prelude_code': 'def IsReverseTopologicalOrder (R : Finset AtomicResidualState) (ord : List AtomicResidualState) : Prop :=\n  ord.Nodup ∧\n  (∀ q : AtomicResidualState, q ∈ ord ↔ q ∈ R) ∧\n  ∀ q r : AtomicResidualState, q ∈ R → r ∈ R → AtomicResidualGraphStep q r → ord.idxOf r < ord.idxOf q\n\ndef ReverseTopologicalSweep\n    (p : AtomicResidualState) (R : Finset AtomicResidualState)\n    (ord : List AtomicResidualState) (good : AtomicResidualState → Bool) : Prop :=\n  IsReverseTopologicalOrder R ord ∧\n  ∀ q : AtomicResidualState, q ∈ R →\n    (good q = true ↔\n      q = ([# (p.2)], p.2) ∨\n        ∃ r : AtomicResidualState, r ∈ R ∧ AtomicResidualGraphStep q r ∧ good r = true)', 'formalized_stmt': '∀ (Γ : List Tp) (A : Tp) (p : AtomicResidualState),\n  residualAtomicState Γ A = some p →\n    ∃ R : Finset AtomicResidualState,\n      (∀ q : AtomicResidualState, q ∈ R ↔ Relation.ReflTransGen AtomicResidualGraphStep p q) ∧\n      ∃ ord₀ : List AtomicResidualState,\n        ∃ good₀ : AtomicResidualState → Bool,\n          ReverseTopologicalSweep p R ord₀ good₀ ∧\n          ∀ ord : List AtomicResidualState,\n            ∀ good : AtomicResidualState → Bool,\n              ReverseTopologicalSweep p R ord good →\n              (∀ q : AtomicResidualState, q ∈ R → good q = good₀ q) ∧\n              (∀ q : AtomicResidualState, q ∈ R → (good q = true ↔ AtomicResidualGraphAccepts q))', 'prelude_code': '', 'prover_statement_result': 'ok', 'prover_attempts_used': 1, 'priority_refresh_ran': False, 'priority_refresh_error': "priority refresh output missing problem_ids: ['op_000074']", 'expand_candidates': [], 'stored_expand_rows': [], 'promoted_expand_rows': [], 'batch_generator_added_problem_rows': [], 'batch_generator_error': '', 'pending_expand_candidate_count': 9, 'archived_problem_count': 40, 'active_open_problem_count': 9, 'iteration': 22}
