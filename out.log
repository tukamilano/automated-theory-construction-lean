   ∀ {p qq}, qq ∈ branches p → p ∈ states ∧ qq.1 ∈ states ∧ qq.2 ∈ states\n\ninductive FiniteAtomicBranchingAccepts (M : FiniteAtomicBranchingAutomaton) :\n    AtomicResidualState → Prop where\n  | base {s : String} (hmem : ([# s], s) ∈ M.states) :\n      FiniteAtomicBranchingAccepts M ([# s], s)\n  | step {p q₁ q₂ : AtomicResidualState}\n      (hbranch : (q₁, q₂) ∈ M.branches p)\n      (hleft : FiniteAtomicBranchingAccepts M q₁)\n      (hright : FiniteAtomicBranchingAccepts M q₂) :\n      FiniteAtomicBranchingAccepts M p', 'formalized_stmt': '∀ (Γ : List Tp) (A : Tp),\n  ∃ M : FiniteAtomicBranchingAutomaton,\n    (∀ p ∈ M.states, ResidualStateSubformulaBound Γ A p) ∧\n    ∀ (Δ : List Tp) (s : String),\n      residualAtomicState Γ A = some (Δ, s) →\n        (Δ, s) ∈ M.states ∧\n        (AtomicResidualGraphAccepts (Δ, s) ↔ FiniteAtomicBranchingAccepts M (Δ, s))', 'prelude_code': '', 'prover_statement_result': 'ok', 'prover_attempts_used': 2, 'priority_refresh_ran': True, 'priority_refresh_error': '', 'expand_candidates': [], 'stored_expand_rows': [], 'promoted_expand_rows': [], 'batch_generator_added_problem_rows': [], 'batch_generator_error': '', 'pending_expand_candidate_count': 3, 'archived_problem_count': 13, 'active_open_problem_count': 4, 'iteration': 1}
